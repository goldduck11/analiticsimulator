# Используем образ с Node.js
FROM node:20-alpine

# Указываем рабочую папку внутри контейнера
WORKDIR /app

# Копируем файлы зависимостей
COPY package*.json ./

# Устанавливаем библиотеки
RUN npm install

# Копируем все остальные исходники фронта
COPY . .

# Открываем порт (тот, на котором работает твой фронт, обычно 3000 или 5173)
EXPOSE 3000

# Запускаем сервер фронтенда
# ВАЖНО: замени 'dev' на ту команду, которую ты пишешь в консоли (например, 'start' или 'serve')
CMD ["npm", "run", "dev"]